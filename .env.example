# KW Srishti LeadBot — Environment Variables
# Copy this to Railway's "Variables" section

# REQUIRED
PORT=3000
ADMIN_PASSWORD=change_this_to_something_secure

# OPTIONAL — enables AI fallback via Claude API
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# OPTIONAL — SQLite path (Railway volume)
DB_PATH=/app/data/leads.db

# OPTIONAL — restrict CORS to your domain
# ALLOWED_ORIGINS=https://yourdomain.com
